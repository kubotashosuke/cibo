<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/md_surface_container_lowest"
    android:paddingHorizontal="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- ドラッグハンドル -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            app:tint="@color/md_primary"
            android:src="@drawable/ic_filter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="絞り込み"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface" />

    </LinearLayout>

    <!-- 店名 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="店名"
        android:textSize="12sp"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.GourmetSearch.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/filterNameEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="店名で絞り込む"
            android:inputType="text"
            android:imeOptions="actionNext" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ジャンル -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ジャンル"
        android:textSize="12sp"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.GourmetSearch.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/filterGenreEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例: カフェ、居酒屋、和食"
            android:inputType="text"
            android:imeOptions="actionDone" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 予算 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="予算"
        android:textSize="12sp"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="6dp" />
    <Spinner
        android:id="@+id/filterBudgetSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/spinner_background"
        android:paddingHorizontal="14dp"
        android:popupBackground="@color/md_surface_container_lowest" />

    <!-- ボタン行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterClearButton"
            style="@style/Widget.GourmetSearch.Button.Text"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="クリア" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterApplyButton"
            style="@style/Widget.GourmetSearch.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="適用" />

    </LinearLayout>

</LinearLayout>