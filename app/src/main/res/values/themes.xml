<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GourmetSearch" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md_on_tertiary_container</item>

        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>
        <item name="colorErrorContainer">@color/md_error_container</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container</item>

        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>

        <item name="colorSurfaceContainerLowest">@color/md_surface_container_lowest</item>
        <item name="colorSurfaceContainerLow">@color/md_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/md_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/md_surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/md_surface_container_highest</item>

        <item name="android:statusBarColor">@color/md_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/md_surface_container_lowest</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="bottomNavigationStyle">@style/Widget.GourmetSearch.BottomNavigation</item>
        <item name="chipStyle">@style/Widget.GourmetSearch.Chip.Choice</item>
        <item name="materialButtonStyle">@style/Widget.GourmetSearch.Button</item>
        <item name="floatingActionButtonStyle">@style/Widget.GourmetSearch.Fab</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.GourmetSearch.BottomSheet</item>
    </style>

    <!-- ===== Bottom Navigation ===== -->
    <style name="Widget.GourmetSearch.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.GourmetSearch.BottomNavigation.ActiveIndicator</item>
        <item name="elevation">3dp</item>
    </style>

    <style name="Widget.GourmetSearch.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_primary_container</item>
    </style>

    <!-- ===== Choice Chip（絞り込み条件） ===== -->
    <style name="Widget.GourmetSearch.Chip.Choice" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipStrokeColor">@color/md_outline_variant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">36dp</item>
    </style>

    <!-- ===== ボタン ===== -->
    <style name="Widget.GourmetSearch.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/md_primary</item>
        <item name="android:textColor">@color/md_on_primary</item>
    </style>

    <style name="Widget.GourmetSearch.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/md_outline</item>
        <item name="android:textColor">@color/md_primary</item>
        <item name="iconTint">@color/md_primary</item>
    </style>

    <style name="Widget.GourmetSearch.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/md_on_surface_variant</item>
    </style>

    <!-- ===== FAB ===== -->
    <style name="Widget.GourmetSearch.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/md_primary_container</item>
        <item name="tint">@color/md_on_primary_container</item>
    </style>

    <!-- ===== BottomSheet ===== -->
    <style name="ThemeOverlay.GourmetSearch.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.GourmetSearch.BottomSheet</item>
    </style>

    <style name="Widget.GourmetSearch.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/md_surface_container_lowest</item>
        <item name="shapeAppearance">@style/ShapeAppearance.GourmetSearch.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.GourmetSearch.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ===== TextInputLayout（絞り込みフォーム） ===== -->
    <style name="Widget.GourmetSearch.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_primary</item>
        <item name="hintTextColor">@color/md_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

</resources>
